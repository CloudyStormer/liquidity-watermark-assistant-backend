APP_NAME=Watermark Assistant API
APP_ENV=local
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
STORAGE_DIR=storage
DATABASE_PATH=storage/app.db
MAX_UPLOAD_BYTES=209715200
FFMPEG_PATH=ffmpeg
DAILY_FREE_QUOTA=3
INPAINT_ENGINE=local
AI_INPAINT_URL=
AI_INPAINT_API_KEY=
AI_INPAINT_TIMEOUT_SECONDS=45
WEAPP_APPID=your_wechat_miniprogram_appid
WEAPP_SECRET=your_wechat_miniprogram_appsecret
WEAPP_CONTENT_SECURITY_ENABLED=true
WEAPP_ACCESS_TOKEN_URL=https://api.weixin.qq.com/cgi-bin/token
WEAPP_CODE2SESSION_URL=https://api.weixin.qq.com/sns/jscode2session
WEAPP_MSG_SEC_CHECK_URL=https://api.weixin.qq.com/wxa/msg_sec_check
WEAPP_IMG_SEC_CHECK_URL=https://api.weixin.qq.com/wxa/img_sec_check
WEAPP_LOGIN_TIMEOUT_SECONDS=6
WEAPP_SEC_CHECK_TIMEOUT_SECONDS=10
